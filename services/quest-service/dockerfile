# Stage 1: The Builder (Keep this for the lockfile export)
FROM python:3.12-slim AS builder
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv
WORKDIR /app
COPY pyproject.toml uv.lock ./
COPY services/quest-service/pyproject.toml ./services/quest-service/
RUN uv export --frozen --no-dev --package quest-service -o requirements.txt

# Stage 2: The Runtime (Now with UV)
FROM python:3.12-slim
WORKDIR /app

# ⚔️ WITCHER TRICK: Copy uv into the final runtime stage
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

# Install system dependencies for Postgres
RUN apt-get update && apt-get install -y libpq-dev gcc && rm -rf /var/lib/apt/lists/*

# Install Python dependencies using the exported requirements
COPY --from=builder /app/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source code
COPY services/quest-service/ /app/services/quest-service/

# Set environment variables
ENV PYTHONPATH="/app:/app/services/quest-service"
ENV PYTHONUNBUFFERED=1
# Ensure uv uses the system python environment inside the container
ENV UV_SYSTEM_PYTHON=1 

WORKDIR /app/services/quest-service
EXPOSE 8000

CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]